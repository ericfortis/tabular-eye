<idea-plugin>
  <id>com.ericfortis.tabulareye</id>
  <name>Tabular Eye</name>
  <version>0.0.1</version>
  <vendor>Eric Fortis</vendor>

  <depends>com.intellij.modules.platform</depends>
  <depends optional="true" config-file="tabular-eye-js.xml">JavaScript</depends>
  <depends optional="true" config-file="tabular-eye-css.xml">com.intellij.css</depends>
  <depends optional="true" config-file="tabular-eye-yaml.xml">org.jetbrains.plugins.yaml</depends>
  <depends optional="true" config-file="tabular-eye-json.xml">com.intellij.modules.json</depends>
  <depends optional="true" config-file="tabular-eye-python.xml">PythonCore</depends>
  <depends optional="true" config-file="tabular-eye-sql.xml">com.intellij.database</depends>

  <extensionPoints>
    <extensionPoint name="alignmentDetector" interface="com.ericfortis.tabulareye.detectors.AlignmentDetector"
                    dynamic="true"/>
  </extensionPoints>

  <extensions defaultExtensionNs="com.intellij">
    <applicationService serviceImplementation="com.ericfortis.tabulareye.DetectorSettings"/>
    <applicationConfigurable
        parentId="tools"
        instance="com.ericfortis.tabulareye.DetectorSettingsConfigurable"
        displayName="Tabular Eye"/>
    <editorFactoryListener implementation="com.ericfortis.tabulareye.TabularEye"/>

    <applicationService serviceImplementation="com.ericfortis.syntaxeye.SyntaxEyeSettings"/>
    <applicationConfigurable
        parentId="tools"
        instance="com.ericfortis.syntaxeye.SyntaxEyeConfigurable"
        displayName="Syntax Eye"/>
    <editorFactoryListener implementation="com.ericfortis.syntaxeye.SyntaxEyeHighlighter"/>
    <additionalTextAttributes scheme="Default" file="colorSchemes/SyntaxEyeDefault.xml"/>
    <additionalTextAttributes scheme="Darcula" file="colorSchemes/SyntaxEyeDarcula.xml"/>
    <colorSettingsPage implementation="com.ericfortis.syntaxeye.SyntaxEyeColorSettingsPage"/>
  </extensions>

  <extensions defaultExtensionNs="com.ericfortis.tabulareye">
    <alignmentDetector implementation="com.ericfortis.tabulareye.detectors.NginxDetector"/>
    <alignmentDetector implementation="com.ericfortis.tabulareye.detectors.WhitespaceAlignmentDetector"/>
  </extensions>
</idea-plugin>
